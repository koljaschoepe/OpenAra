#!/bin/bash
# Arasul MOTD — show detected platform info on SSH login

# Detect platform and model (matches detect.sh strategy)
if [[ -f /etc/nv_tegra_release ]] || dpkg -l nvidia-l4t-core &>/dev/null || \
   { [[ -f /proc/device-tree/compatible ]] && grep -qi "tegra" /proc/device-tree/compatible 2>/dev/null; }; then
    MODEL=$(tr '\0' '\n' < /proc/device-tree/model 2>/dev/null | head -1)
    CUDA_VER=$(python3 -c 'import json,pathlib;print(json.loads(pathlib.Path("/usr/local/cuda/version.json").read_text())["cuda"]["version"])' 2>/dev/null \
        || nvcc --version 2>/dev/null | grep -oP 'release \K[\d.]+' || echo "")
    GPU_INFO="${CUDA_VER:+ | CUDA $CUDA_VER}"
elif [[ -f /proc/device-tree/model ]] && grep -qi "raspberry" /proc/device-tree/model 2>/dev/null; then
    MODEL=$(tr '\0' '\n' < /proc/device-tree/model 2>/dev/null | head -1)
    GPU_INFO=""
else
    MODEL=$(uname -n)
    GPU_INFO=""
fi

RAM=$(free -m 2>/dev/null | awk '/^Mem:/{printf "%.0fGB", $2/1024}')
ARCH=$(uname -m)
UPTIME=$(uptime -p 2>/dev/null | sed 's/^up //' || echo "unknown")

echo ""
echo "  Arasul | ${MODEL} | ${RAM} RAM | ${ARCH}${GPU_INFO}"
echo "  Up ${UPTIME}"
echo ""
