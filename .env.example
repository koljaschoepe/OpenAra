# =============================================================================
# Arasul — Device Configuration
# =============================================================================
# This file is auto-generated by the setup wizard. You can also create it
# manually: cp .env.example .env && nano .env
#
# Only CUSTOMER_NAME and DEVICE_USER are required.
# Everything else has sensible defaults or is auto-detected.
# =============================================================================

# --- Required ---
CUSTOMER_NAME="CHANGEME"                  # Project name (e.g. "my-lab", "home-server")
DEVICE_USER="CHANGEME"                    # Your username on this device
DEVICE_HOSTNAME="dev"                     # Hostname — reachable as <hostname>.local via mDNS

# --- Platform & Storage (auto-detected if empty) ---
PLATFORM=""                               # "jetson" | "raspberry_pi" | "generic"
STORAGE_DEVICE=""                         # e.g. "/dev/nvme0n1" — auto-detected if empty
STORAGE_MOUNT=""                          # e.g. "/mnt/nvme" — auto-detected if empty
SWAP_SIZE="32G"                           # Swap file size (wizard adjusts for low-RAM devices)

# --- Network ---
INSTALL_TAILSCALE="false"                 # "true" for remote access outside LAN
STATIC_IP=""                              # Empty = DHCP, or e.g. "192.168.1.100/24"
STATIC_GATEWAY=""                         # e.g. "192.168.1.1" (only when STATIC_IP is set)

# --- Git (optional — configure later with: git config --global user.name) ---
GIT_USER_NAME=""                          # e.g. "John Doe"
GIT_USER_EMAIL=""                         # e.g. "john@example.com"

# --- Development Tools ---
NODE_VERSION="22"                         # Node.js LTS version
INSTALL_CLAUDE="true"                     # Claude Code CLI
INSTALL_OLLAMA="false"                    # Local LLM inference (needs 8GB+ RAM)
INSTALL_ARASUL_TUI="true"                # Arasul interactive TUI

# --- Power Management (Jetson only, ignored on other platforms) ---
POWER_MODE="3"                            # 0=7W, 1=15W, 3=25W (recommended), MAXN=max

# --- Docker ---
DOCKER_LOG_MAX_SIZE="10m"                 # Max size per log file
DOCKER_LOG_MAX_FILES="3"                  # Max number of rotated log files

# --- n8n Workflow Automation ---
INSTALL_N8N="false"                       # "true" to install n8n + PostgreSQL
